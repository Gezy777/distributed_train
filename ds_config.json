{
  "train_batch_size": 16384,
  "train_micro_batch_size_per_gpu": 128,
  "gradient_accumulation_steps": 128,
  "steps_per_print": 10,
  "optimizer": {
    "type": "Adam",
    "params": {
      "lr": 0.001,
      "betas": [0.9, 0.999],
      "eps": 1e-8,
      "weight_decay": 1e-4
    }
  },
  "zero_optimization": {
    "stage": 0
  },
  "gradient_clipping": 1.0,
  "wall_clock_breakdown": false,
  "pipeline": {
    "seed_layers": true,
    "activation_checkpointing": true,
    "overlap_comm": true
  }
}